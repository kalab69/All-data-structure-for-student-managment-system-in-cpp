            cout << "Id:" << temp->id << endl;
            cout << "CGPA: " << temp->cgpa << endl;
            cout << "Department: " << temp->department << endl;
        }
        temp = temp->prev;
    }
}

// Stack

class student_stack
{
public:
    int top = -1;
    int id[100];
    string name[100];
    double cgpa[100];
    string department[100];
    student_stack()
    {
        top = -1;
    }
    void push(string Name, int Id, double Cgpa, string Department)
    {
        if (top == 99)
        {
            cout << "Stack overflow\n";
        }
        else
        {
            top++;
            id[top] = Id;
            name[top] = Name;
            cgpa[top] = Cgpa;
            department[top] = Department;
        }
    }
    void pop()
    {
        if (top == -1)
        {
            cout << "Stack underflow\n";
        }
        else
        {
            cout << "Removed: \n"
                 << "Name: " << name[top] << endl;
            cout << "ID: " << id[top] << endl;
            cout << "CGPA: " << cgpa[top] << endl;
            cout << "Department: " << department[top] << endl;
            top--;
        }
    }
    void peek()
    {
        if (top == -1)
        {
            cout << "Stack empty\n";
        }
        else
        {
            cout << "Top element: \n";
            cout << "Name: " << name[top] << endl;
            cout << "ID: " << id[top] << endl;
            cout << "CGPA: " << cgpa[top] << endl;
            cout << "Department: " << department[top] << endl;
        }
    }
    void display()
    {
        if (top == -1)
        {
            cout << "Stack empty\n";
            return;
        }

        for (int i = top; i >= 0; i--)
        {
            cout << "----------------------\n";
            cout << "Name: " << name[i] << endl;
            cout << "ID: " << id[i] << endl;
            cout << "CGPA: " << cgpa[i] << endl;
            cout << "Department: " << department[i] << endl;
        }
    }
    void search(int value)
    {
        if (top == -1)
        {
            cout << "Quque empty\n";
            return;
        }
        for (int i = top; i >= 0; i--)
        {
            if (id[i] == value)
            {
                cout << "----------------------\n";
                cout << "Name: " << name[i] << endl;
                cout << "ID: " << id[i] << endl;
                cout << "CGPA: " << cgpa[i] << endl;
                cout << "Department: " << department[i] << endl;
                break;
            }
        }
    }
};

// Quque

class student_quque
{
public:
    int id[100];
    string name[100];
    double cgpa[100];
    string department[100];
    int front;
    int rear;
    student_quque()
    {
        front = 0;
        rear = -1;
    }
    void enquque(string Name, int Id, double Cgpa, string Department)
    {
        if (rear == 99)
        {
            cout << "Quque overflow\n";
        }
        else
        {
            rear++;
            id[rear] = Id;
            name[rear] = Name;
            cgpa[rear] = Cgpa;
            department[rear] = Department;
        }
    }
    void deque()
    {
        if (front > rear)
        {
            cout << "Quque underflow\n";
        }
        else
        {
            cout << "Removed \n"
                 << "Name: " << name[front] << endl;
            cout << "ID: " << id[front] << endl;
            cout << "CGPA: " << cgpa[front] << endl;
            cout << "Department: " << department[front] << endl;
            front++;
        }
    }

    void peek()
    {
        if (front > rear)
        {
            cout << "Quque empty\n";
        }
        else
        {
            cout << "Front element " << "Name: " << name[front] << endl;
            cout << "ID: " << id[front] << endl;
            cout << "CGPA: " << cgpa[front] << endl;
            cout << "Department: " << department[front] << endl;
        }
    }
    void display_quque()
    {
        if (front > rear)
        {
            cout << "Quque empty\n";
            return;
        }
        for (int i = front; i <= rear; i++)
        {
            cout << "Name: " << name[i] << endl;
            cout << "ID: " << id[i] << endl;
            cout << "CGPA: " << cgpa[i] << endl;
            cout << "Department: " << department[i] << endl;
        }
    }
    void search(int value)
    {
        if (front > rear)
        {
            cout << "Quque empty\n";
        }
        for (int i = front; i <= rear; i++)
        {
            if (id[i] == value)
            {
                cout << "Name: " << name[i] << endl;
                cout << "ID: " << id[i] << endl;
                cout << "CGPA: " << cgpa[i] << endl;
                cout << "Department: " << department[i] << endl;
                break;
            }
        }
    }
};

// Tree/graph

class student_tree
{
public:
    string name;
    int id;
    double cgpa;
    string department;
    student_tree *right;
    student_tree *left;
    student_tree(string Name, int ID, double Cgpa, string Departmen)
    {
        name = Name;
        id = ID;
        cgpa = Cgpa;
        department = Departmen;
        right = NULL;
        left = NULL;
    }
};
student_tree *insert_tree(student_tree *root, string name, int id, double cgpa, string department)
{
    if (root == NULL)
        return new student_tree(name, id, cgpa, department);

    if (id == root->id)
    {
        cout << "Student with this ID already exists\n";
        return root;
    }

    if (id < root->id)
        root->left = insert_tree(root->left, name, id, cgpa, department);
    else
        root->right = insert_tree(root->right, name, id, cgpa, department);

    return root;
}
student_tree *findMin(student_tree *node)
{
    while (node->left != NULL)
        node = node->left;
    return node;
}

student_tree *delete_node(student_tree *root, int id, bool &found)
{

    // Base case: empty tree
    if (root == NULL)
    {
        cout << "Student not found\n";
        return NULL;
    }

    // Step 1: Navigate to the node
    if (id < root->id)
    {
        root->left = delete_node(root->left, id, found); // go left
    }
    else if (id > root->id)
    {
        root->right = delete_node(root->right, id, found); // go right
    }
    else
    {
        // Found it! Now handle the 3 cases:
        found = true;
        // CASE 1: Leaf node (no children)
        if (root->left == NULL && root->right == NULL)
        {
            delete root;
            return NULL;
        }

        // CASE 2a: Only right child
        else if (root->left == NULL)
        {
            student_tree *temp = root->right;
            delete root;
            return temp;
        }

        // CASE 2b: Only left child
        else if (root->right == NULL)
        {
            student_tree *temp = root->left;
            delete root;
            return temp;
        }

        // CASE 3: Two children
        else
        {
            // Find inorder successor (smallest in right subtree)
            student_tree *successor = findMin(root->right);

            // Copy successor's data into this node
            root->name = successor->name;
            root->id = successor->id;
            root->cgpa = successor->cgpa;
            root->department = successor->department;

            // Delete the successor from the right subtree
            root->right = delete_node(root->right, successor->id, found);
        }
    }
    return root;
}
void display_tree_inorder(student_tree *root)
{
    if (root == NULL)
    {
        return;
    }
    display_tree_inorder(root->left);
    cout << "----------------------\n";
    cout << "Name: " << root->name << endl;
    cout << "ID: " << root->id << endl;
    cout << "CGPA: " << root->cgpa << endl;
    cout << "Department: " << root->department << endl;

    display_tree_inorder(root->right);
}
void display_tree_postorder(student_tree *root)
{
    if (root == NULL)
    {
        return;
    }
    display_tree_postorder(root->left);
    display_tree_postorder(root->right);
    cout << "----------------------\n";
    cout << "Name: " << root->name << endl;
    cout << "ID: " << root->id << endl;
    cout << "CGPA: " << root->cgpa << endl;
    cout << "Department: " << root->department << endl;
}
void display_tree_preorder(student_tree *root)
{
    if (root == NULL)
    {
        return;
    }
    cout << "----------------------\n";
    cout << "Name: " << root->name << endl;
    cout << "ID: " << root->id << endl;
    cout << "CGPA: " << root->cgpa << endl;
    cout << "Department: " << root->department << endl;
    display_tree_preorder(root->left);
    display_tree_preorder
    
    (root->right);
}
void search_tree(student_tree *root, int value)
{
    if (root == NULL)
    {
        cout << "Empty tree\n";
        return;
    }
    if (root->id == value)
    {
        cout << "----------------------\n";
        cout << "Name: " << root->name << endl;
        cout << "ID: " << root->id << endl;
        cout << "CGPA: " << root->cgpa << endl;
        cout << "Department: " << root->department << endl;
        return;
    }
    if (value > root->id)
    {
        search_tree(root->right, value);
    }
    else
    {
        search_tree(root->left, value);
    }
}

