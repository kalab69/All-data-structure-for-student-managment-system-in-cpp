    {

        cout << "----------------------\n";
        cout << "Name: " << temp->name << endl;
        cout << "ID: " << temp->id << endl;
        cout << "CGPA: " << temp->cgpa << endl;
        cout << "Department: " << temp->department << endl;

        temp = temp->prev;
    }

    cout << "----------------------\n";
}

void search_doubly_linkedlist(Student_doubly_linked_list *head, int id)
{

    if (head == NULL)
    {
        cout << "List empty\n";
        return;
    }
    Student_doubly_linked_list *temp = head;
    while (temp->next != NULL)
    {
        temp = temp->next;
    }
    while (temp != NULL)
    {
        if (temp->id == id)
        {
