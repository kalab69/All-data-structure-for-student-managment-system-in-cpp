// Single linked list

struct Student_linked_list
{
public:
    string name;
    int id;
    double cgpa;
    string department;
    Student_linked_list *next;
};

void insert_studentAtBegining(Student_linked_list *&head, string Name, int ID, double Cgpa, string Department)
{
    Student_linked_list *s = new Student_linked_list();
    s->name = Name;
    s->id = ID;
    s->cgpa = Cgpa;
    s->department = Department;
    s->next = head;
    head = s;
}
void deleteAtTheBegining(Student_linked_list *&head)
{
    if (head == NULL)
    {
        cout << "No Value To Delete\n";
        return;
    }
    Student_linked_list *temp = head;
    head = head->next;

    delete temp;
}

void display(Student_linked_list *head)
{

    if (head == NULL)
    {
        cout << "List is empty.\n";
        return;
    }

    Student_linked_list *temp = head;

    while (temp != NULL)
    {

        cout << "----------------------\n";
        cout << "Name: " << temp->name << endl;
        cout << "ID: " << temp->id << endl;
        cout << "CGPA: " << temp->cgpa << endl;
        cout << "Department: " << temp->department << endl;

        temp = temp->next;
    }

    cout << "----------------------\n";
}
void search_linkedlist(Student_linked_list *head, int id)
{
    Student_linked_list *temp = head;
    while (temp != NULL)
    {
        if (temp->id == id)
        {
            cout << "Found\n";
            cout << "Name: " << temp->name << endl;
            cout << "Id:" << temp->id << endl;
            cout << "CGPA: " << temp->cgpa << endl;
            cout << "Department: " << temp->department << endl;
        }
        temp = temp->next;
    }
}

// doubly linked list

struct Student_doubly_linked_list
{
public:
    string name;
    int id;
    double cgpa;
    string department;
    Student_doubly_linked_list *next;
    Student_doubly_linked_list *prev;
};
void insert_doubly_studentAtBegining(Student_doubly_linked_list *&head, string Name, int ID, double Cgpa, string Department)
{
    Student_doubly_linked_list *s = new Student_doubly_linked_list();
    s->name = Name;
    s->id = ID;
    s->cgpa = Cgpa;
    s->department = Department;
    s->next = head;
    s->prev = NULL;
    if (head != NULL)
    {
        head->prev = s;
    }
    head = s;
}
void delete_doubly_AtTheBegining(Student_doubly_linked_list *&head)
{
    if (head == NULL)
    {
        cout << "No Value To Delete\n";
        return;
    }
    Student_doubly_linked_list *temp = head;
    head = head->next;
    if (head != NULL)
    {
        head->prev = NULL;
    }

    delete temp;
}

void display_doubly_backwards(Student_doubly_linked_list *head)
{

    if (head == NULL)
    {
        cout << "List is empty.\n";
        return;
    }

    Student_doubly_linked_list *temp = head;
    while (temp->next != NULL)
    {
        temp = temp->next;
    }

